{
  "description": "sdlc-workflow-codex native hooks (Node). Review and trust before activation.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/session-start.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\session-start.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "timeout": 30,
            "statusMessage": "Activating SDLC workflow runtime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/pre-tool-use.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\pre-tool-use.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "timeout": 5,
            "statusMessage": "Validating managed artifact write"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/post-tool-use.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\post-tool-use.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "timeout": 15,
            "statusMessage": "Verifying managed artifacts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/stop-verify.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\stop-verify.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "timeout": 20,
            "statusMessage": "Final managed-artifact check"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/stop-verify.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\stop-verify.mjs\" --plugin-root \"${PLUGIN_ROOT}\" --plugin-data \"${PLUGIN_DATA}\"",
            "timeout": 20,
            "statusMessage": "Final managed-artifact check (subagent)"
          }
        ]
      }
    ]
  }
}
