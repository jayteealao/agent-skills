{
  "router": "/wf-quick",
  "description": "Routing-resolution fixtures for the /wf-quick skill (v9.0.0-alpha.2+). Each invocation should resolve to skills/wf-quick/reference/<key>.md based on the first positional token.",
  "fixtures": [
    {
      "id": "wf-quick-rca-incident",
      "purpose": "rca sub-command with two positional args (incident slug + date).",
      "invocation": "/wf-quick rca payment-timeout 2026-04-30",
      "expectedReferencePath": "skills/wf-quick/reference/rca.md"
    },
    {
      "id": "wf-quick-fix-slug",
      "purpose": "Original /wf-quick semantics reached via the 'fix' key (renamed from 'quick' in v9.18.0).",
      "invocation": "/wf-quick fix add-rate-limiting",
      "expectedReferencePath": "skills/wf-quick/reference/fix.md"
    },
    {
      "id": "wf-quick-quick-rejected",
      "purpose": "'quick' was renamed to 'fix' in v9.18.0. Router must reject with a redirect message rather than silently treat it as a slug.",
      "invocation": "/wf-quick quick add-rate-limiting",
      "expectedBehavior": "error",
      "expectedReferencePath": null
    },
    {
      "id": "wf-quick-intake-rejected",
      "purpose": "intake is no longer a /wf-quick sub-command (relocated to /wf in v9.1.0). Router must reject rather than silently treat it as a slug.",
      "invocation": "/wf-quick intake support OAuth callback flow",
      "expectedBehavior": "error",
      "expectedReferencePath": null
    },
    {
      "id": "wf-quick-update-deps-hyphen-key",
      "purpose": "Hyphenated key (update-deps) parses correctly.",
      "invocation": "/wf-quick update-deps",
      "expectedReferencePath": "skills/wf-quick/reference/update-deps.md"
    },
    {
      "id": "wf-quick-ideate-no-args",
      "purpose": "Sub-command with optional args; bare-key invocation is valid.",
      "invocation": "/wf-quick ideate",
      "expectedReferencePath": "skills/wf-quick/reference/ideate.md"
    },
    {
      "id": "wf-quick-investigate-domain",
      "purpose": "investigate sub-command with explicit domain.",
      "invocation": "/wf-quick investigate payments",
      "expectedReferencePath": "skills/wf-quick/reference/investigate.md"
    },
    {
      "id": "wf-quick-discover-problem",
      "purpose": "discover with a multi-word problem statement (everything after the key is the problem).",
      "invocation": "/wf-quick discover users abandon checkout flow",
      "expectedReferencePath": "skills/wf-quick/reference/discover.md"
    },
    {
      "id": "wf-quick-hotfix-incident",
      "purpose": "hotfix with active-incident description.",
      "invocation": "/wf-quick hotfix payment-timeout breaking checkout",
      "expectedReferencePath": "skills/wf-quick/reference/hotfix.md"
    },
    {
      "id": "wf-quick-refactor-target",
      "purpose": "refactor with explicit target.",
      "invocation": "/wf-quick refactor src/auth/session.ts",
      "expectedReferencePath": "skills/wf-quick/reference/refactor.md"
    },
    {
      "id": "wf-quick-unknown-key",
      "purpose": "Unknown first token must NOT be silently treated as a slug. Router prints an error listing valid keys.",
      "invocation": "/wf-quick foobar add-rate-limiting",
      "expectedBehavior": "error",
      "expectedReferencePath": null
    },
    {
      "id": "wf-quick-no-args-menu",
      "purpose": "Bare /wf-quick should render the menu, not pick a default sub-command.",
      "invocation": "/wf-quick",
      "expectedBehavior": "menu",
      "expectedReferencePath": null
    }
  ]
}
