      "invocation": "/wf review add-onboarding triage",
      "expectedReferencePath": "skills/wf/reference/review.md"
    },
    {
      "id": "wf-handoff-slug",
      "purpose": "handoff with slug.",
      "invocation": "/wf handoff add-onboarding",
      "expectedReferencePath": "skills/wf/reference/handoff.md"
    },
    {
      "id": "wf-ship-slug",
      "purpose": "ship with slug.",
      "invocation": "/wf ship add-onboarding",
      "expectedReferencePath": "skills/wf/reference/ship.md"
    },
    {
      "id": "wf-retro-slug",
      "purpose": "retro with slug.",
      "invocation": "/wf retro add-onboarding",
      "expectedReferencePath": "skills/wf/reference/retro.md"
    },
    {
      "id": "wf-instrument-slug",
      "purpose": "instrument augmentation with slug.",
      "invocation": "/wf instrument add-onboarding",
      "expectedReferencePath": "skills/wf/reference/instrument.md"
    },
    {
      "id": "wf-experiment-slug",
      "purpose": "experiment augmentation with slug.",
      "invocation": "/wf experiment add-onboarding",
      "expectedReferencePath": "skills/wf/reference/experiment.md"
    },
    {
      "id": "wf-benchmark-baseline",
      "purpose": "benchmark with mode (baseline before implement).",
      "invocation": "/wf benchmark baseline add-onboarding",
      "expectedReferencePath": "skills/wf/reference/benchmark.md"
    },
    {
      "id": "wf-benchmark-compare",
      "purpose": "benchmark with mode (compare after implement).",
      "invocation": "/wf benchmark compare add-onboarding",
      "expectedReferencePath": "skills/wf/reference/benchmark.md"
    },
    {
      "id": "wf-profile-area",
      "purpose": "profile against an explicit code area.",
      "invocation": "/wf profile src/auth/session.ts",
      "expectedReferencePath": "skills/wf/reference/profile.md"
    },
    {
      "id": "wf-unknown-key",
      "purpose": "Unknown first token must NOT be silently treated as a slug. Router prints an error listing valid keys.",
      "invocation": "/wf foobar add-onboarding",
      "expectedBehavior": "error",
      "expectedReferencePath": null
    },
    {
      "id": "wf-no-args-menu",
      "purpose": "Bare /wf should render the menu, not pick a default sub-command.",
      "invocation": "/wf",
      "expectedBehavior": "menu",
      "expectedReferencePath": null
    }
  ]
