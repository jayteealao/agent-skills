{
  "name": "warm-paper",
  "type": "light",
  "colors": {
    "editor.background": "#f3f1ea",
    "editor.foreground": "#1f1b16"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a8377", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": { "foreground": "#8c5a4a" }
    },
    {
      "scope": ["string", "punctuation.definition.string", "string.template"],
      "settings": { "foreground": "#6a7d4e" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character", "variable.other.constant"],
      "settings": { "foreground": "#8c6d3f" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#4a6c8c" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#3f6d6a" }
    },
    {
      "scope": ["variable", "variable.parameter", "meta.definition.variable"],
      "settings": { "foreground": "#1f1b16" }
    },
    {
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#4a443c" }
    },
    {
      "scope": ["punctuation", "meta.brace", "keyword.operator"],
      "settings": { "foreground": "#6b6457" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#8c5a4a" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#8c6d3f" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#1f1b16", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#4a6c8c" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#4a6c8c" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#b5305f" }
    }
  ]
}
