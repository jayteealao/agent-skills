{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anthropic.com/plugins/sdlc-workflow/sdlc-config.schema.json",
  "title": "SDLC Workflow Local Configuration",
  "description": "Optional per-project configuration for sdlc-workflow view rendering, bootstrap, serve, and hook behavior. Store at .ai/sdlc-config.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "render": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32,
              "default": 4
            },
            "debounceMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 60000,
              "default": 2000
            }
          }
        },
        "serve": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "host": {
              "type": "string",
              "default": "127.0.0.1"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 4173
            },
            "liveReload": {
              "type": "boolean",
              "default": true
            },
            "tailscale": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "mode": {
                  "enum": ["serve", "funnel"],
                  "default": "serve"
                },
                "path": {
                  "type": "string",
                  "pattern": "^/",
                  "default": "/"
                },
                "https": {
                  "type": "boolean",
                  "default": true
                },
                "acknowledgedPublic": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "bootstrap": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "renderMissing": {
              "type": "boolean",
              "default": true
            },
            "renderStale": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoStage": {
          "type": "boolean",
          "default": true
        },
        "validateOnWrite": {
          "type": "boolean",
          "default": true
        },
        "verifyOnWrite": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
